# Copia este archivo a .env y completa los valores.
# (.env está en .gitignore — no lo subas)

# ── Servidor ─────────────────────────────────────────────
PORT=3000

# Cuántos videos se procesan A LA VEZ (default 1 si se omite)
WORKER_CONCURRENCY=1

# ── Panel admin (Basic Auth) ─────────────────────────────
# Acceso solo por túnel al VPS. Cambia estos valores en producción.
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# ── MongoDB (compartido con el CRM) ──────────────────────
MONGO_URI=mongodb+srv://usuario:password@host/
DB_NAME=nombre_de_la_db

# ── Redis (BullMQ) ───────────────────────────────────────
# En docker-compose.local.yml se sobreescribe REDIS_HOST=redis automáticamente.
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Backblaze B2 (S3-compatible) ─────────────────────────
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=

# ── Reconciler (opcional) ────────────────────────────────
RECONCILER_INTERVAL_MS=300000
RECONCILER_STALE_MS=120000
